<%= link_to term_path(term), class: "group block min-w-0" do %>
  <% if term.image.attached? %>
    <div class="term-card term-card--image">
      <%= image_tag url_for(term.image),
          class: "max-w-full max-h-full object-contain rounded-[8px]",
          alt: term.term %>
    </div>
  <% else %>
    <div class="term-card">
      <span class="term-card__arrow">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M4 12L12 4M12 4H5.5M12 4V10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <div class="term-card__body">
        <h3 class="term-card__title"><%= term.term %></h3>
        <p class="term-card__desc">
          <%= truncate(term.definition.to_s.lines.first.to_s.strip, length: 160) %>
        </p>
      </div>
    </div>
  <% end %>
<% end %>
