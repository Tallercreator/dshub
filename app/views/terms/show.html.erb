<% content_for :title, "#{@term.term} — Глоссарий DSHub" %>

<section class="w-[1440px] mx-auto px-[32px] pt-[56px] pb-[80px] relative overflow-hidden">

  <%# ==================== DECORATIVE BRUSH STROKES ==================== %>
  <img aria-hidden="true"
       src="<%= asset_path('glossary/brushes.svg') %>"
       class="pointer-events-none select-none absolute left-0 right-0 top-[-40px] w-full h-auto z-0"
       alt="">

  <%# ==================== TITLE ==================== %>
  <h1 class="relative z-10 text-center text-[80px] font-display font-[450] leading-[1] tracking-[-0.04em] text-neutral-160 m-0">
    <%= @term.term %>
  </h1>

  <%# ==================== 3 COLUMNS ==================== %>
  <div class="relative z-10 flex justify-between mt-[56px]">
    <div class="w-[332px] flex flex-col gap-2">
      <h3 class="text-[14px] font-display font-medium text-neutral-80 leading-none">Определение</h3>
      <p class="text-[14px] text-neutral-160 leading-[1.2]">
        <%= @term.definition.presence || "—" %>
      </p>
    </div>

    <div class="w-[332px] flex flex-col gap-2">
      <h3 class="text-[14px] font-display font-medium text-neutral-80 leading-none">Для чего нужен</h3>
      <p class="text-[14px] text-neutral-160 leading-[1.2]">
        <%= @term.purpose.presence || "—" %>
      </p>
    </div>

    <div class="w-[332px] flex flex-col gap-2">
      <h3 class="text-[14px] font-display font-medium text-neutral-80 leading-none">Где используется</h3>
      <p class="text-[14px] text-neutral-160 leading-[1.2]">
        <%= @term.context.presence || "—" %>
      </p>
    </div>
  </div>

  <%# ==================== MAIN IMAGE (only if attached) ==================== %>
  <% if @term.image.attached? %>
    <div class="mt-[64px] bg-neutral-10 rounded-[24px] h-[594px] flex items-center justify-center p-[100px]">
      <%= image_tag url_for(@term.image),
          class: "max-w-full max-h-full object-contain",
          alt: @term.term %>
    </div>
  <% end %>

  <%# ==================== EXAMPLES OF USAGE (only if attached) ==================== %>
  <% if @term.examples.attached? && @term.examples.any? %>
    <div class="mt-[64px] flex flex-col gap-6">
      <h2 class="text-[32px] font-display font-[450] leading-none tracking-[-0.04em] text-neutral-160">
        Пример использования
      </h2>
      <div class="grid grid-cols-2 gap-[16px]">
        <% @term.examples.each do |example| %>
          <div class="bg-neutral-10 rounded-[8px] overflow-hidden h-[660px]">
            <%= image_tag url_for(example),
                class: "w-full h-full object-cover",
                alt: "Пример использования #{@term.term}" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ==================== MENTIONED IN CASES ==================== %>
  <% if @mentioned_cases.any? %>
    <div class="mt-[64px] flex flex-col gap-6">
      <h2 class="text-[32px] font-display font-[450] leading-none tracking-[-0.04em] text-neutral-160">
        Взято из кейса:
      </h2>
      <div class="flex gap-[16px] flex-wrap">
        <% @mentioned_cases.each do |kase| %>
          <%= render partial: "shared/case_card", locals: { kase: kase } %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ==================== MORE TERMS ==================== %>
  <% if @more_terms.any? %>
    <div class="mt-[80px]">
      <h2 class="text-[48px] font-display font-[450] leading-none tracking-[-0.04em] text-neutral-160" style="margin: 0;">
        Изучать ещё
      </h2>
      <div style="height: 32px;"></div>
      <div class="grid grid-cols-5 gap-[16px]">
        <% @more_terms.each do |t| %>
          <%= render partial: "terms/card", locals: { term: t } %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
